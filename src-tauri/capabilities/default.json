{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "protium default capability — enge scopes, kein wildcard (INV-7). sekundär-libraries werden zur laufzeit via allow_library_scope (R-5) ergänzt.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.local/share/Steam" },
        { "path": "$HOME/.local/share/Steam/**" },
        { "path": "$HOME/.steam" },
        { "path": "$HOME/.steam/**" },
        { "path": "$HOME/.var/app/com.valvesoftware.Steam" },
        { "path": "$HOME/.var/app/com.valvesoftware.Steam/**" },
        { "path": "$APPCACHE" },
        { "path": "$APPCACHE/**" },
        { "path": "$APPCONFIG" },
        { "path": "$APPCONFIG/**" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://www.protondb.com/*" },
        { "url": "https://api.github.com/*" },
        { "url": "https://github.com/*" },
        { "url": "https://objects.githubusercontent.com/*" }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://www.protondb.com/*" }]
    }
  ]
}
